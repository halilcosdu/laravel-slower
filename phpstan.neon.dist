includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    # Tell larastan where this package keeps its config and views so the
    # env()-in-config and view-name checks resolve against the real files.
    configDirectories:
        - config
    viewDirectories:
        - resources/views

